DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Local default database.
DB_ENGINE=sqlite
SQLITE_DB_NAME=db.sqlite3

# Optional PostgreSQL settings. Set DB_ENGINE=postgres to use these.
POSTGRES_DB=n_feed
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Optional Redis cache. If empty, local dev uses Django's in-memory cache.
REDIS_URL=
