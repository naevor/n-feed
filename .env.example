DJANGO_ENV=dev
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost,http://127.0.0.1

# Local default database.
DB_ENGINE=sqlite
SQLITE_DB_NAME=db.sqlite3

# Optional PostgreSQL settings. Set DB_ENGINE=postgres to use these.
POSTGRES_DB=n_feed
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Optional Redis cache. If empty, local dev uses Django's in-memory cache.
REDIS_URL=
CHANNEL_LAYER_REDIS_URL=

# Celery. Local dev runs tasks eagerly by default; Docker uses Redis.
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=
CELERY_TASK_ALWAYS_EAGER=True
DEFAULT_FROM_EMAIL=noreply@n-feed.local
MAX_AVATAR_UPLOAD_SIZE=2097152
MAX_TWEET_MEDIA_UPLOAD_SIZE=5242880
DATA_UPLOAD_MAX_MEMORY_SIZE=10485760
FILE_UPLOAD_MAX_MEMORY_SIZE=5242880
MEDIA_THUMBNAIL_MAX_SIZE=512

# Optional S3-compatible media storage. Keep False for local filesystem uploads.
USE_S3_STORAGE=False
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_STORAGE_BUCKET_NAME=n-feed-media
AWS_S3_ENDPOINT_URL=http://localhost:9000
AWS_S3_REGION_NAME=us-east-1
AWS_S3_CUSTOM_DOMAIN=
AWS_S3_ADDRESSING_STYLE=path
AWS_QUERYSTRING_AUTH=False
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# Production-only toggles. Docker Compose disables these for local HTTP.
DJANGO_SECURE_SSL_REDIRECT=True
DJANGO_COOKIE_SECURE=True
DJANGO_SECURE_HSTS_SECONDS=31536000
DJANGO_LOG_LEVEL=INFO
